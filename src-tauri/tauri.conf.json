{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "XEditor",
  "version": "1.0.0",
  "identifier": "TareqHossain.XEditor",
  "build": {
    "beforeDevCommand": "npm start",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist/xnote/browser"
  },
  "app": {
    "windows": [
      {
        "title": "XEditor",
        "width": 800,
        "height": 600,
        "center": true,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "CN=BB255EEE-5F6E-4824-999C-6D811490BB1E",
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller"
      },
      "nsis": {
        "displayLanguageSelector": false,
        "installMode": "perMachine",
        "installerHooks": "bundle/nsis/installer-hooks.nsi"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}